# KickPool — Environment Variables
# Copy to .env.local for local dev

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://kickpool:kickpool@localhost:5432/kickpool?schema=public"

# ── NextAuth ──────────────────────────────────────────────────────
NEXTAUTH_SECRET="kickpool-dev-secret-change-in-prod"
NEXTAUTH_URL="http://localhost:3000"

# ── Socket server ─────────────────────────────────────────────────
NEXT_PUBLIC_SOCKET_URL="http://localhost:4000"

# ── TxLINE ───────────────────────────────────────────────────────
# Base URL (mainnet by default)
TXLINE_BASE_URL="https://txline.txodds.com"
# API token obtained after on-chain subscribe tx
# Leave blank for first run — the app will auto-acquire a guest JWT
TXLINE_API_TOKEN=""

# ── Solana ───────────────────────────────────────────────────────
# mainnet-beta | devnet
SOLANA_NETWORK="devnet"
# Set to true to skip real on-chain txs (uses simulated wallet + fake escrow)
DEMO_MODE="true"

# ── AI Commentary ────────────────────────────────────────────────
# Google Gemini for AI Pundit (falls back to rule-based templates if missing)
GOOGLE_API_KEY=""
# OR
GEMINI_API_KEY=""

# ── Optional: Redis ───────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Email (Resend) ────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="KickPool <noreply@kickpool.app>"

# ── TMDB (still used by base CinePurr features) ───────────────────
TMDB_API_KEY=""

# ── Logging ───────────────────────────────────────────────────────
# LOG_LEVEL=debug
