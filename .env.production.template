# KickPool Production Environment
# Set ALL of these in Vercel Dashboard > Settings > Environment Variables

# ── Database (use Neon.tech free tier: neon.tech) ──────────────────
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/kickpool?sslmode=require"

# ── NextAuth ────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_32_CHAR_SECRET"
NEXTAUTH_URL="https://kickpool.vercel.app"

# ── Socket server (Railway URL after deploy) ────────────────────────
NEXT_PUBLIC_SOCKET_URL="https://kickpool-server.up.railway.app"

# ── TxLINE ──────────────────────────────────────────────────────────
TXLINE_BASE_URL="https://txline.txodds.com"
# Leave blank initially — activated via on-chain subscribe in the UI
TXLINE_API_TOKEN=""

# ── Solana ──────────────────────────────────────────────────────────
SOLANA_NETWORK="devnet"
NEXT_PUBLIC_SOLANA_NETWORK="devnet"
DEMO_MODE="false"

# ── AI Commentary (Google AI Studio: aistudio.google.com) ───────────
GOOGLE_API_KEY="REPLACE_WITH_GEMINI_KEY"

# ── Optional ────────────────────────────────────────────────────────
REDIS_URL=""
RESEND_API_KEY=""
TMDB_API_KEY=""
NEXT_TELEMETRY_DISABLED="1"
