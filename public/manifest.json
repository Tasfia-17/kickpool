      "label": "Home page"
    },
    {
      "src": "/screenshots/room.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Pool room"
    }
  ],
  "shortcuts": [
    {
      "name": "Create Pool",
      "short_name": "New Pool",
      "description": "Start a new World Cup sweepstakes pool",
      "url": "/pool/create",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Join Pool",
      "short_name": "Join",
      "description": "Join an existing pool with invite code",
      "url": "/pool/join",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "My Profile",
      "short_name": "Profile",
      "description": "View your profile and winnings",
      "url": "/profile",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }]
    }
  ],
  "handle_links": "preferred",
