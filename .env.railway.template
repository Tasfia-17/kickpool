# KickPool Socket Server — Railway Environment Variables
# Set ALL of these in Railway Dashboard > Variables

# ── Database (same Neon URL as Vercel) ─────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/kickpool?sslmode=require"

# ── NextAuth (same secret as Vercel) ───────────────────────────────
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_32_CHAR_SECRET"

# ── CORS — set to your Vercel URL ──────────────────────────────────
CORS_ORIGIN="https://kickpool.vercel.app"

# ── TxLINE ─────────────────────────────────────────────────────────
TXLINE_BASE_URL="https://txline.txodds.com"
TXLINE_API_TOKEN=""

# ── Solana ─────────────────────────────────────────────────────────
SOLANA_NETWORK="devnet"
DEMO_MODE="false"

# ── AI Commentary ──────────────────────────────────────────────────
GOOGLE_API_KEY="REPLACE_WITH_GEMINI_KEY"

# ── Server port (Railway sets this automatically) ──────────────────
PORT="4000"

# ── Admin bridge secret (same as NEXTAUTH_SECRET) ──────────────────
ADMIN_API_KEY="REPLACE_WITH_RANDOM_32_CHAR_SECRET"

# ── Optional Redis ─────────────────────────────────────────────────
REDIS_URL=""
